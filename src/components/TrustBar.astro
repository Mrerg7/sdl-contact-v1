---
import { SITE } from '../config/site';
---

<div class="border-b border-white/10 bg-zinc-950">
  <div class="max-w-screen-xl mx-auto px-6 py-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-6 text-center">
      <div>
        <div class="metric gradient-text">3L</div>
        <div class="text-sm text-zinc-500 tracking-wide mt-1">SHORT ACRONYM</div>
      </div>
      <div>
        <div class="metric text-white">340%</div>
        <div class="text-sm text-zinc-500 tracking-wide mt-1">.CONTACT TLD GROWTH</div>
      </div>
      <div>
        <div class="metric text-white">4</div>
        <div class="text-sm text-zinc-500 tracking-wide mt-1">VERTICAL POSITIONS</div>
      </div>
      <div>
        <div class="metric text-emerald-400">24H</div>
        <div class="text-sm text-zinc-500 tracking-wide mt-1">RESPONSE TIME</div>
      </div>
    </div>
  </div>
</div>
