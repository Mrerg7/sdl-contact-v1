---
import { SITE } from '../config/site';
---

<nav id="nav" class="fixed top-0 w-full z-50 transition-all duration-300">
  <div class="max-w-screen-xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-x-3 group" aria-label={SITE.name}>
      <div class="w-10 h-10 bg-white/10 rounded-2xl flex items-center justify-center border border-white/15 group-hover:border-white/30 transition-colors">
        <span class="text-white font-display font-bold text-xl tracking-tighter">SDL</span>
      </div>
      <span class="text-white font-display font-semibold text-xl tracking-tighter">
        sdl<span class="text-desert-gold">.</span>contact
      </span>
    </a>

    <div class="hidden md:flex items-center gap-x-6 text-sm font-medium">
      <a href="#use-cases" class="text-zinc-400 hover:text-white transition-colors">Use Cases</a>
      <a href="#market" class="text-zinc-400 hover:text-white transition-colors">Market</a>
      <a href="#value" class="text-zinc-400 hover:text-white transition-colors">Value</a>
      <a href="#acquire" class="text-zinc-400 hover:text-white transition-colors">Acquire</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('nav-scrolled', 'border-b', 'border-white/10');
    } else {
      nav?.classList.remove('nav-scrolled', 'border-b', 'border-white/10');
    }
  });
</script>
