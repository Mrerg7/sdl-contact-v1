---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
import AcquisitionCTA from './AcquisitionCTA.astro';
---

<footer id="acquire" class="relative border-t border-white/10 bg-black">
  <!-- Sophisticated domain acquisition CTA -->
  <div class="footer-cta-glow relative overflow-hidden">
    <div class="absolute inset-0 tech-grid opacity-40 pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-desert-gold/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative max-w-screen-xl mx-auto px-6 py-20 md:py-28">
      <div class="glass rounded-[2rem] border border-desert-gold/25 p-8 md:p-14 text-center md:text-left">
        <div class="grid md:grid-cols-12 gap-10 items-center">
          <div class="md:col-span-7 space-y-5">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-[2px] text-emerald-400">Available for Acquisition</span>
            </div>

            <h2 class="text-3xl sm:text-5xl font-display tracking-tight leading-tight">
              Acquire <span class="gradient-text">{SITE.name}</span> — a premium digital asset for visionary builders
            </h2>

            <p class="text-lg text-zinc-400 max-w-xl">
              For domain investors, local platforms, B2B SaaS founders, and enterprise buyers seeking a short, versatile .contact domain. Direct owner negotiation — no brokers. Escrow available.
            </p>

            <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-2 text-left">
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-zinc-500 mb-1">Characters</dt>
                <dd class="font-bold text-white">11</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-zinc-500 mb-1">TLD</dt>
                <dd class="font-bold text-white">.contact</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-zinc-500 mb-1">Range</dt>
                <dd class="font-bold text-white">$24K–$48K</dd>
              </div>
              <div>
                <dt class="text-[10px] uppercase tracking-widest text-zinc-500 mb-1">Transfer</dt>
                <dd class="font-bold text-emerald-400">Immediate</dd>
              </div>
            </dl>
          </div>

          <div class="md:col-span-5 flex flex-col items-center md:items-stretch gap-5">
            <div class="w-full p-6 rounded-2xl bg-zinc-950/80 border border-white/10 text-center md:text-left">
              <div class="text-xs uppercase tracking-[2px] text-zinc-500 mb-2 font-semibold">Acquisition Contact</div>
              <a
                href={ACQUISITION_MAILTO}
                class="text-xl sm:text-2xl font-display font-semibold text-desert-gold hover:text-desert-gold/80 transition-colors break-all"
              >
                {SITE.email}
              </a>
              <p class="text-sm text-zinc-500 mt-3">Response within 24 hours. Escrow available.</p>
            </div>

            <AcquisitionCTA
              variant="gradient"
              size="md"
              label="Inquire About sdl.contact"
              class="w-full !rounded-2xl"
            />

            <p class="text-[11px] text-zinc-600 text-center md:text-left leading-relaxed">
              By contacting us, you acknowledge this is a demonstration listing. Terms subject to negotiation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Legal disclaimer + meta footer -->
  <div class="max-w-screen-xl mx-auto px-6 pb-12">
    <div class="pt-10 border-t border-white/10">
      <p class="text-xs text-zinc-600 leading-relaxed max-w-4xl mb-8">
        This website is for demonstration and informational purposes only. It does not constitute an offer of services,
        a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
        technologies are based on publicly available information as of {SITE.lastUpdated} and are subject to change.
      </p>

      <div class="flex flex-col md:flex-row gap-y-4 items-start md:items-center justify-between text-xs text-zinc-500">
        <div>© {new Date().getFullYear()} {SITE.name} — Premium Strategic Asset</div>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <span>{SITE.location}</span>
          <span>Clean Title</span>
          <span>Ready for Immediate Transfer</span>
        </div>
        <a href={ACQUISITION_MAILTO} class="hover:text-white transition-colors font-medium">
          {SITE.email}
        </a>
      </div>
    </div>
  </div>
</footer>
