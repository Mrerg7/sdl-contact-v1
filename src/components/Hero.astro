---
import { ACQUISITION_MAILTO, CF_IMAGES, SITE } from '../config/site';
import AcquisitionCTA from './AcquisitionCTA.astro';
import CloudflareImage from './CloudflareImage.astro';
---

<section class="hero-bg min-h-screen flex flex-col pt-16 relative tech-grid">
  <!-- Full-width hero visual -->
  <div class="w-full px-4 sm:px-6 pt-6 pb-8">
    <div
      class="max-w-screen-xl mx-auto rounded-3xl overflow-hidden border border-desert-gold/25 shadow-[0_0_100px_rgb(180,83,9,0.2)] ring-1 ring-white/10"
    >
      <CloudflareImage
        src={CF_IMAGES.hero}
        alt="sdl.contact — Premium short .contact domain for acquisition"
        width={1920}
        height={1080}
        loading="eager"
        fetchpriority="high"
        class="w-full h-auto object-cover aspect-[21/9] sm:aspect-[2.4/1] min-h-[200px] sm:min-h-[280px] md:min-h-[360px]"
      />
    </div>
  </div>

  <div class="max-w-screen-xl mx-auto px-6 pb-20 w-full flex-1 flex items-center">
    <div class="grid xl:grid-cols-12 gap-12 items-center w-full">
      <div class="xl:col-span-7 max-w-3xl">
        <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-full bg-zinc-900 border border-desert-gold/30 mb-8">
          <div class="w-2 h-2 bg-desert-gold rounded-full animate-pulse"></div>
          <span class="uppercase tracking-[2.2px] text-xs font-extrabold text-desert-gold">
            Premium Short Domain • .contact TLD
          </span>
        </div>

        <h1 class="text-5xl sm:text-7xl md:text-[84px] leading-[0.93] font-display tracking-[-3.6px] mb-7">
          Own <span class="gradient-text">{SITE.name}</span><br />
          Your direct line to<br />Scottsdale &amp; beyond.
        </h1>

        <p class="max-w-lg text-xl sm:text-2xl text-zinc-400 mb-10">
          Short. Direct. Unforgettable.<br />
          A 3-letter .contact domain with versatile positioning — Scottsdale, Sales Development, Secure Digital Link, or your own vision.
        </p>

        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <AcquisitionCTA variant="gradient" size="md" label="Acquire sdl.contact" class="!text-lg w-full sm:w-auto" />
          <a
            href="#use-cases"
            class="group px-8 py-4 border border-white/30 hover:border-white/70 rounded-3xl flex items-center justify-center gap-x-3 text-lg transition-all w-full sm:w-auto"
          >
            <span>Explore the opportunity</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-y-1 transition" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

        <div class="mt-9 flex items-center gap-x-7 text-sm text-zinc-500">
          <div class="flex items-center gap-x-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Escrow protected • Instant transfer</span>
          </div>
        </div>
      </div>

      <div class="xl:col-span-5">
        <div class="glass px-8 py-6 rounded-3xl border border-desert-gold/20">
          <div class="text-xs uppercase tracking-[1.5px] text-desert-gold mb-2 font-bold">Premium Short Domain</div>
          <div class="text-4xl font-extrabold mb-1">{SITE.name}</div>
          <div class="text-sm text-zinc-400 mb-5">Only 11 characters. 3-letter .contact with unlimited brand potential.</div>
          <div class="pt-4 border-t border-white/10 flex justify-between items-end">
            <div>
              <div class="text-xs text-zinc-500">Asking Range</div>
              <div class="text-2xl font-bold text-white">$24K – $48K</div>
            </div>
            <div class="text-[10px] px-3 py-1 bg-emerald-500/10 text-emerald-400 rounded-full font-bold">Available</div>
          </div>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-5 block text-center text-sm font-bold text-desert-gold hover:text-desert-gold/80 transition-colors"
          >
            Inquire → {SITE.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
