---
import { ACQUISITION_MAILTO, SITE } from '../config/site';

interface Props {
  variant?: 'primary' | 'secondary' | 'gradient' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  label?: string;
}

const {
  variant = 'primary',
  size = 'md',
  class: className = '',
  label = 'Acquire sdl.contact',
} = Astro.props;

const sizeClasses = {
  sm: 'px-6 py-2.5 text-sm',
  md: 'px-10 py-4 text-base',
  lg: 'px-14 py-5 text-xl',
};

const variantClasses = {
  primary:
    'bg-white text-black hover:bg-zinc-100 font-extrabold shadow-2xl',
  secondary:
    'border border-white/30 hover:border-white/70 text-white font-semibold',
  gradient:
    'gradient-accent text-white font-extrabold shadow-[0_0_50px_rgb(180,83,9,0.4)] hover:scale-[1.015] active:scale-[0.985]',
  outline:
    'border border-white text-white font-extrabold hover:bg-white hover:text-black',
};

const classes = [
  'inline-flex items-center justify-center gap-x-3 rounded-3xl transition-all',
  sizeClasses[size],
  variantClasses[variant],
  className,
]
  .filter(Boolean)
  .join(' ');
---

<a href={ACQUISITION_MAILTO} class={classes} aria-label={`${label} — email ${SITE.email}`}>
  <span>{label}</span>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
  </svg>
</a>
