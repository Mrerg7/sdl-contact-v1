---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | sdl.contact" description="The page you were looking for could not be found.">
  <meta name="robots" content="noindex" />
  <main class="min-h-screen flex items-center justify-center px-6 hero-bg">
    <div class="text-center max-w-md">
      <div class="text-8xl font-display font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl font-display font-semibold mb-3">Page Not Found</h1>
      <p class="text-zinc-400 mb-8">The page you're looking for doesn't exist. Perhaps you're interested in acquiring the domain instead?</p>
      <a
        href="/"
        class="inline-flex items-center gap-x-2 px-8 py-3 gradient-accent text-white font-semibold rounded-3xl hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to sdl.contact
      </a>
    </div>
  </main>
</BaseLayout>
